# ─────────────────────────────────────────────────────
# DevMetric — Root Environment Variables
# ─────────────────────────────────────────────────────
# Copy this file to .env and fill in the values.
#   cp .env.example .env

# Google AI Studio key (required by ai-service)
GOOGLE_API_KEY=

# Gemini model name (optional, default: gemini-2.5-flash-lite)
# GEMINI_MODEL=gemini-2.5-flash-lite

# Host port mappings (optional)
# GATEWAY_PORT=8080
# FRONTEND_PORT=3000
